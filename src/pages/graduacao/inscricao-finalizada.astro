---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { GraduationThankYouPage } from '@/thankyou/GraduationThankYouPage'

const title = 'Inscrição finalizada | Graduação | Faculdade Paulista'
const description = 'Recebemos sua inscrição para a graduação.'
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/graduacao/inscricao-finalizada"
  noindex={true}
>
  <GraduationThankYouPage client:load />
</BaseLayout>
