---
import type { CoursePresentation } from '../coursePageData'

interface Props {
  presentation: CoursePresentation
}

const { presentation } = Astro.props

const modalityLabel = (presentation.modalityLabel || 'EAD').toUpperCase()

const items = [
  {
    title: 'Estude onde e quando quiser',
    text: 'Conteúdo acessível para se adaptar ao seu ritmo. Você tem a liberdade de organizar seus horários e estudar de onde estiver, perfeito para sua rotina.',
  },
  {
    title: 'Suporte Humanizado',
    text: 'Você nunca estará sozinho; nossa equipe acadêmica oferece auxílio individualizado. Você conta com suporte em cada etapa, garantindo que as suas dúvidas sejam sanadas.',
  },
  {
    title: 'Diploma de Peso',
    text: 'Certificação reconhecida pelo MEC, garantindo a validade das suas competências em todo o território nacional.',
  },
]
---

<section class="course-page__grad-benefits" aria-labelledby="graduation-benefits-title">
  <div class="course-page__shell">
    <div class="course-page__grad-benefits-inner">
      <div class="course-page__grad-benefits-heading">
        <p class="course-page__grad-benefits-heading-top" id="graduation-benefits-title">
          A graduação {modalityLabel} na Faculdade Paulista é a
        </p>
        <h2 class="course-page__grad-benefits-heading-bottom">Escolha certa para você</h2>
      </div>

      <div class="course-page__grad-benefits-grid">
        {items.map((item) => (
          <article class="course-page__grad-benefits-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>

      <a class="course-page__grad-benefits-cta" href="#course-form">
        Inscreva-se já
      </a>
    </div>
  </div>
</section>
