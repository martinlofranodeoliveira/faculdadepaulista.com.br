---
import GraduationCategoryPage from '@/course/GraduationCategoryPage.astro'
import { getGraduationCategoryCourses } from '@/course/graduationCategoryData'
import BaseLayout from '@/layouts/BaseLayout.astro'

export const prerender = false

const courses = await getGraduationCategoryCourses()
const title = 'Graduação | Faculdade Paulista'
const description =
  'Conheça os cursos de Graduação da Faculdade Paulista e navegue pelas páginas de curso com estrutura preparada para SEO.'
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Graduação Faculdade Paulista',
  description,
  url: 'https://faculdadepaulista.com.br/graduacao',
}
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/graduacao"
  structuredData={structuredData}
>
  <GraduationCategoryPage courses={courses} />
</BaseLayout>

