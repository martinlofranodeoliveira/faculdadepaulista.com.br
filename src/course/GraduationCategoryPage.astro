---
import { FooterSection } from '@/landing/components/FooterSection'
import { Header } from '@/landing/components/Header'

import CategoryBreadcrumb from './components/CategoryBreadcrumb.astro'
import CategorySwitchBar from './components/CategorySwitchBar.astro'
import GraduationCategoryExplorer from './components/GraduationCategoryExplorer'
import type { GraduationCategoryCourse } from './graduationCategoryData'

import './category.css'

interface Props {
  courses: GraduationCategoryCourse[]
}

const { courses } = Astro.props
---

<Header client:load />

<main class="category-page category-page--graduation">
  <CategorySwitchBar current="graduacao" />

  <div class="category-page__shell">
    <CategoryBreadcrumb currentLabel="Graduação" />
    <GraduationCategoryExplorer client:load courses={courses} />
  </div>
</main>

<FooterSection />

