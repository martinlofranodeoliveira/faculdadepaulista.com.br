---
import RelatedCoursesCarousel from './RelatedCoursesCarousel'

type RelatedCourse = {
  path: string
  title: string
  description: string
  image: string
  courseType: 'graduacao' | 'pos'
  oldInstallmentPrice: string
  currentInstallmentPriceMonthly: string
  modalityBadge: string
}

interface Props {
  courses: RelatedCourse[]
}

const { courses } = Astro.props as Props
---

<RelatedCoursesCarousel client:load courses={courses} variant="post" />
