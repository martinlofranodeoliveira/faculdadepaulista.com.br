---
interface Props {
  current: 'graduacao' | 'pos'
}

const { current } = Astro.props

const items = [
  { key: 'graduacao', label: 'Graduação', href: '/graduacao' },
  { key: 'pos', label: 'Pós-graduação', href: '/pos-graduacao' },
] as const
---

<section class="category-page__switchbar" aria-label="Navegação entre categorias">
  <div class="category-page__shell">
    <nav class="category-page__switchbar-nav">
      {
        items.map((item) => (
          <a
            class:list={[
              'category-page__switchbar-link',
              item.key === current && 'is-current',
            ]}
            href={item.href}
          >
            <span>{item.label}</span>
            <svg aria-hidden="true" viewBox="0 0 16 16" fill="none">
              <path
                d="m4.5 6.5 3.5 3.5 3.5-3.5"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.4"
              />
            </svg>
          </a>
        ))
      }
    </nav>
  </div>
</section>

