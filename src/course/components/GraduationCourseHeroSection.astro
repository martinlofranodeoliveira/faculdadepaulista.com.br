---
import type { CoursePresentation } from '../coursePageData'
import { CourseLeadForm } from '../CourseLeadForm'
import InstitutionRegulationNote from './InstitutionRegulationNote.astro'

interface Props {
  title: string
  leadSubmitted?: boolean
  rawLabel?: string
  courseValue?: string
  courseId?: number
  presentation: CoursePresentation
}

const {
  title,
  leadSubmitted = false,
  rawLabel,
  courseValue,
  courseId,
  presentation,
} = Astro.props
---

<div class="course-page__shell">
  <section class="course-page__grad-hero-grid" id="detalhes">
    <div class="course-page__grad-media-column">
      <figure class="course-page__grad-video-frame">
        <img
          src={presentation.graduationHero.mediaImage}
          alt={presentation.graduationHero.mediaAlt}
          width="659"
          height="371"
          loading="eager"
          decoding="async"
        />
      </figure>

      <div class="course-page__grad-rating-badge" aria-label={presentation.graduationHero.ratingLabel}>
        {presentation.graduationHero.ratingStars ? (
          <span class="course-page__grad-rating-stars" aria-hidden="true">
            {String.fromCharCode(9733).repeat(presentation.graduationHero.ratingStars)}
          </span>
        ) : null}
        <span class="course-page__grad-rating-text">{presentation.graduationHero.ratingLabel}</span>
      </div>

      <div class="course-page__grad-highlights">
        {presentation.graduationHero.highlights.map((item) => (
          <div class="course-page__grad-highlight-item">
            <span class="course-page__grad-highlight-icon-wrap" aria-hidden="true">
              <img
                src={item.icon}
                alt=""
                width="21"
                height="21"
                loading="lazy"
                decoding="async"
                class="course-page__grad-highlight-icon"
              />
            </span>
            <div class="course-page__grad-highlight-copy">
              <strong>{item.title}</strong>
              <p>{item.text}</p>
            </div>
          </div>
        ))}
      </div>

      {presentation.institutionRegulation ? (
        <InstitutionRegulationNote
          variant="graduation"
          copy={presentation.institutionRegulation.copy}
          qrCodeImageUrl={presentation.institutionRegulation.qrCodeImageUrl}
          qrCodeHref={presentation.institutionRegulation.qrCodeHref}
          qrCodeWidth={317}
          qrCodeHeight={101}
        />
      ) : null}

      {presentation.graduationPortarias.length ? (
        <section class="course-page__grad-portarias" aria-labelledby="graduation-portarias-title">
          <h2 id="graduation-portarias-title">Portarias</h2>
          <div class="course-page__grad-portarias-list">
            {presentation.graduationPortarias.map((item) => (
              <article class="course-page__grad-portaria-item">
                <p>
                  <strong>{item.label}:</strong> {item.description}
                </p>
                {item.href ? (
                  <a href={item.href} class="course-page__grad-portaria-link" target="_blank" rel="noreferrer">
                    Abrir
                  </a>
                ) : null}
              </article>
            ))}
          </div>
        </section>
      ) : null}

      <div class="course-page__grad-profile-inline">
        <slot />
      </div>

    </div>

    <aside class="course-page__form-column course-page__form-column--graduation" id="course-form">
      <div class="course-page__form-sticky course-page__form-sticky--graduation">
        <CourseLeadForm
          client:load
          courseType="graduacao"
          courseModality={presentation.modality}
          courseTitle={title}
          courseLabel={rawLabel ?? title}
          courseValue={courseValue}
          courseId={courseId}
          leadSubmitted={leadSubmitted}
          paymentPlanGroups={presentation.paymentPlanGroups}
          paymentPlanOptions={presentation.paymentPlanOptions}
          workloadOptions={presentation.workloadOptions}
          pricing={presentation.pricing}
          showInternshipInfoLink={presentation.showInternshipInfoLink}
        />
      </div>

    </aside>

  </section>
</div>
