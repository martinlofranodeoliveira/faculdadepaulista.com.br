---
import type { CoursePresentation } from '../coursePageData'
import { CourseLeadForm } from '../CourseLeadForm'

interface Props {
  courseType: 'graduacao' | 'pos'
  title: string
  leadSubmitted?: boolean
  rawLabel?: string
  courseValue?: string
  courseId?: number
  presentation: CoursePresentation
}

const {
  courseType,
  title,
  leadSubmitted = false,
  rawLabel,
  courseValue,
  courseId,
  presentation,
} = Astro.props
---

<div class="course-page__shell">
  <section class="course-page__hero-grid course-page__hero-grid--post" id="detalhes">
    <div class="course-page__content-column course-page__content-column--post">
      <article class="course-page__video-card">
        <figure class="course-page__video-frame">
          <img
            src={presentation.image}
            alt={presentation.imageAlt}
            width="720"
            height="460"
            loading="eager"
            decoding="async"
          />
        </figure>

        <div class="course-page__fact-row course-page__fact-row--post">
          {presentation.heroFacts.map((fact, index) => (
            <div
              class={`course-page__fact-item ${
                courseType === 'pos' && index === 2 ? 'course-page__fact-item--workload' : ''
              }`}
            >
              {index === 0 ? (
                <svg
                  class="course-page__fact-icon-svg"
                  width="46"
                  height="46"
                  viewBox="0 0 46 46"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <rect width="45.1273" height="45.1273" rx="22.5636" fill="#F80000"></rect>
                  <rect
                    width="45.1273"
                    height="45.1273"
                    rx="22.5636"
                    fill="url(#course-fact-gradient)"
                  ></rect>
                  <mask
                    id="course-fact-mask"
                    mask-type="alpha"
                    maskUnits="userSpaceOnUse"
                    x="12"
                    y="12"
                    width="21"
                    height="21"
                  >
                    <rect x="12.1289" y="12.1277" width="20.8717" height="20.8717" fill="#D9D9D9"></rect>
                  </mask>
                  <g mask="url(#course-fact-mask)">
                    <path
                      d="M25.4133 22.9765L22.1521 19.6936L24.5654 17.302L23.9349 16.6716L19.1735 21.4329L17.956 20.2154L22.6956 15.454C23.0435 15.1062 23.4529 14.9322 23.924 14.9322C24.3951 14.9322 24.8045 15.1062 25.1524 15.454L25.7829 16.0845L26.8699 14.9975C27.0439 14.8235 27.2504 14.7366 27.4896 14.7366C27.7287 14.7366 27.9353 14.8235 28.1092 14.9975L30.1311 17.0194C30.3051 17.1933 30.392 17.3999 30.392 17.639C30.392 17.8782 30.3051 18.0847 30.1311 18.2587L25.4133 22.9765ZM17.9995 30.3903H14.7383V27.1291L20.9128 20.9329L24.1958 24.194L17.9995 30.3903Z"
                      fill="white"
                    ></path>
                  </g>
                  <defs>
                    <linearGradient
                      id="course-fact-gradient"
                      x1="-1.53057"
                      y1="308.37"
                      x2="48.8279"
                      y2="308.186"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop stop-color="#FE0000"></stop>
                      <stop offset="1" stop-color="#FE0066"></stop>
                    </linearGradient>
                  </defs>
                </svg>
              ) : index === 1 ? (
                <svg
                  class="course-page__fact-icon-svg"
                  width="46"
                  height="46"
                  viewBox="0 0 46 46"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <rect width="45.1273" height="45.1273" rx="22.5636" fill="#F80000"></rect>
                  <rect
                    width="45.1273"
                    height="45.1273"
                    rx="22.5636"
                    fill="url(#course-fact-hours-gradient)"
                  ></rect>
                  <mask
                    id="course-fact-hours-mask"
                    mask-type="alpha"
                    maskUnits="userSpaceOnUse"
                    x="12"
                    y="12"
                    width="21"
                    height="21"
                  >
                    <rect x="12.5508" y="12.5522" width="20.0229" height="20.0229" fill="#D9D9D9"></rect>
                  </mask>
                  <g mask="url(#course-fact-hours-mask)">
                    <path
                      d="M19.2239 29.2378H25.8981V26.735C25.8981 25.8173 25.5714 25.0317 24.9179 24.3781C24.2643 23.7246 23.4787 23.3978 22.561 23.3978C21.6433 23.3978 20.8577 23.7246 20.2041 24.3781C19.5506 25.0317 19.2239 25.8173 19.2239 26.735V29.2378ZM15.8867 30.9064V29.2378H17.5553V26.735C17.5553 25.8868 17.7534 25.0908 18.1497 24.3468C18.546 23.6029 19.0987 23.0085 19.8079 22.5636C19.0987 22.1186 18.546 21.5242 18.1497 20.7803C17.7534 20.0364 17.5553 19.2403 17.5553 18.3921V15.8893H15.8867V14.2207H29.2353V15.8893H27.5667V18.3921C27.5667 19.2403 27.3686 20.0364 26.9723 20.7803C26.576 21.5242 26.0233 22.1186 25.3141 22.5636C26.0233 23.0085 26.576 23.6029 26.9723 24.3468C27.3686 25.0908 27.5667 25.8868 27.5667 26.735V29.2378H29.2353V30.9064H15.8867Z"
                      fill="white"
                    ></path>
                  </g>
                  <defs>
                    <linearGradient
                      id="course-fact-hours-gradient"
                      x1="-1.53057"
                      y1="308.37"
                      x2="48.8279"
                      y2="308.186"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop stop-color="#FE0000"></stop>
                      <stop offset="1" stop-color="#FE0066"></stop>
                    </linearGradient>
                  </defs>
                </svg>
              ) : index === 2 ? (
                <svg
                  class="course-page__fact-icon-svg"
                  width="46"
                  height="46"
                  viewBox="0 0 46 46"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <rect width="45.1273" height="45.1273" rx="22.5636" fill="#F80000"></rect>
                  <rect
                    width="45.1273"
                    height="45.1273"
                    rx="22.5636"
                    fill="url(#course-fact-duration-gradient)"
                  ></rect>
                  <mask
                    id="course-fact-duration-mask"
                    mask-type="alpha"
                    maskUnits="userSpaceOnUse"
                    x="12"
                    y="12"
                    width="21"
                    height="21"
                  >
                    <rect x="12.5508" y="12.5522" width="20.0229" height="20.0229" fill="#D9D9D9"></rect>
                  </mask>
                  <g mask="url(#course-fact-duration-mask)">
                    <path
                      d="M21.6849 26.3598L26.3986 21.6461L25.2098 20.4572L21.6849 23.9821L19.9121 22.2092L18.7232 23.3981L21.6849 26.3598ZM19.6305 30.3122C18.7197 29.9159 17.9272 29.3806 17.2528 28.7062C16.5784 28.0318 16.0431 27.2393 15.6468 26.3285C15.2505 25.4177 15.0524 24.4409 15.0524 23.3981C15.0524 22.3552 15.2505 21.3784 15.6468 20.4677C16.0431 19.5569 16.5784 18.7643 17.2528 18.0899C17.9272 17.4156 18.7197 16.8802 19.6305 16.4839C20.5413 16.0877 21.5181 15.8895 22.5609 15.8895C23.6038 15.8895 24.5806 16.0877 25.4914 16.4839C26.4021 16.8802 27.1947 17.4156 27.8691 18.0899C28.5434 18.7643 29.0788 19.5569 29.4751 20.4677C29.8714 21.3784 30.0695 22.3552 30.0695 23.3981C30.0695 24.4409 29.8714 25.4177 29.4751 26.3285C29.0788 27.2393 28.5434 28.0318 27.8691 28.7062C27.1947 29.3806 26.4021 29.9159 25.4914 30.3122C24.5806 30.7085 23.6038 30.9067 22.5609 30.9067C21.5181 30.9067 20.5413 30.7085 19.6305 30.3122ZM17.2215 14.5129L18.3895 15.6809L14.8438 19.2267L13.6758 18.0587L17.2215 14.5129ZM27.9004 14.5129L31.4461 18.0587L30.2781 19.2267L26.7324 15.6809L27.9004 14.5129Z"
                      fill="white"
                    ></path>
                  </g>
                  <defs>
                    <linearGradient
                      id="course-fact-duration-gradient"
                      x1="-1.53057"
                      y1="308.37"
                      x2="48.8279"
                      y2="308.186"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop stop-color="#FE0000"></stop>
                      <stop offset="1" stop-color="#FE0066"></stop>
                    </linearGradient>
                  </defs>
                </svg>
              ) : (
                <span class="course-page__fact-icon" aria-hidden="true"></span>
              )}
              <div class="course-page__fact-copy">
                <strong>{fact.eyebrow}</strong>
                <p>{fact.text}</p>
              </div>
            </div>
          ))}
        </div>

        {courseType === 'pos' ? (
          <div class="course-page__regulation-note course-page__regulation-note--post">
            <div class="course-page__regulation-copy">
              <p>
                O curso de Pós-Graduação ofertado pela Faculdade Fasul Educacional,
                inscrita no CNPJ sob n° 21.558.886/0001-63, Instituição de Ensino Superior
                devidamente credenciada pelo Ministério da Educação (MEC) para a oferta de
                cursos na modalidade a distância (EAD), conforme Portaria n° 499, de
                08/07/2021, DOU de 09/07/2021.
              </p>
              <p>
                A Faculdade Paulista atua exclusivamente na divulgação e gestão comercial e
                educacional dos Cursos.
              </p>
              <p>
                O Certificado de conclusão será emitido pela Faculdade Fasul Educacional,
                nos termos da Legislação vigente.
              </p>
            </div>
            <div class="course-page__regulation-mec-card">
              <img
                src="/course/consulte-mec-qr.webp"
                alt="QR Code para consulta da instituição no sistema e-MEC"
                class="course-page__regulation-mec-qr"
                width="76"
                height="76"
                loading="lazy"
                decoding="async"
              />
              <div class="course-page__regulation-mec-copy">
                <strong>Consulte aqui o cadastro da Instituição no Sistema e-MEC</strong>
                <span>ACESSE JÁ!</span>
              </div>
            </div>
          </div>
        ) : null}
      </article>

      <div class="course-page__info-stack course-page__info-stack--post">
        {presentation.infoCards.map((card, index) => (
          <article class="course-page__info-card course-page__info-card--post">
            {courseType === 'pos' && index === 0 ? (
              <svg class="course-page__info-icon-svg" width="39" height="39" viewBox="0 0 39 39" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <mask id="course-info-mask-1" mask-type="alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="39" height="39">
                  <rect width="38.0179" height="38.0179" fill="#D9D9D9"></rect>
                </mask>
                <g mask="url(#course-info-mask-1)">
                  <path d="M17.4247 33.2663V30.0982H30.0973V18.8512C30.0973 15.7623 29.0214 13.1419 26.8697 10.9902C24.718 8.83853 22.0977 7.76268 19.0087 7.76268C15.9198 7.76268 13.2995 8.83853 11.1478 10.9902C8.99605 13.1419 7.9202 15.7623 7.9202 18.8512V28.5141H6.33612C5.46488 28.5141 4.71904 28.2039 4.09861 27.5834C3.47818 26.963 3.16797 26.2172 3.16797 25.3459V22.1778C3.16797 21.6234 3.30658 21.1019 3.58379 20.6135C3.861 20.1251 4.25042 19.7357 4.75205 19.4452L4.87085 17.3463C5.08206 15.5511 5.60349 13.8878 6.43513 12.3565C7.26677 10.8252 8.30962 9.49196 9.56368 8.35671C10.8177 7.22145 12.2566 6.33701 13.8803 5.70338C15.504 5.06975 17.2135 4.75293 19.0087 4.75293C20.804 4.75293 22.5069 5.06975 24.1174 5.70338C25.7279 6.33701 27.1667 7.21485 28.434 8.33691C29.7013 9.45896 30.7441 10.7856 31.5626 12.3169C32.381 13.8482 32.909 15.5115 33.1466 17.3067L33.2654 19.366C33.7671 19.6037 34.1565 19.9601 34.4337 20.4353C34.7109 20.9105 34.8495 21.4121 34.8495 21.9402V25.5835C34.8495 26.1116 34.7109 26.6132 34.4337 27.0884C34.1565 27.5636 33.7671 27.9201 33.2654 28.1577V30.0982C33.2654 30.9694 32.9552 31.7152 32.3348 32.3357C31.7144 32.9561 30.9685 33.2663 30.0973 33.2663H17.4247ZM14.2565 22.1778C13.8077 22.1778 13.4315 22.026 13.1279 21.7224C12.8242 21.4187 12.6724 21.0425 12.6724 20.5937C12.6724 20.1449 12.8242 19.7687 13.1279 19.465C13.4315 19.1614 13.8077 19.0096 14.2565 19.0096C14.7053 19.0096 15.0816 19.1614 15.3852 19.465C15.6888 19.7687 15.8406 20.1449 15.8406 20.5937C15.8406 21.0425 15.6888 21.4187 15.3852 21.7224C15.0816 22.026 14.7053 22.1778 14.2565 22.1778ZM23.761 22.1778C23.3122 22.1778 22.9359 22.026 22.6323 21.7224C22.3287 21.4187 22.1769 21.0425 22.1769 20.5937C22.1769 20.1449 22.3287 19.7687 22.6323 19.465C22.9359 19.1614 23.3122 19.0096 23.761 19.0096C24.2098 19.0096 24.586 19.1614 24.8896 19.465C25.1932 19.7687 25.3451 20.1449 25.3451 20.5937C25.3451 21.0425 25.1932 21.4187 24.8896 21.7224C24.586 22.026 24.2098 22.1778 23.761 22.1778ZM9.54388 19.7225C9.35907 16.9239 10.2039 14.5214 12.0784 12.5149C13.9529 10.5084 16.2894 9.50516 19.0879 9.50516C21.4377 9.50516 23.5036 10.251 25.2857 11.7427C27.0677 13.2343 28.1436 15.1418 28.5132 17.4652C26.1107 17.4388 23.8996 16.7919 21.8799 15.5247C19.8602 14.2574 18.3091 12.5413 17.2267 10.3764C16.8042 12.4885 15.9132 14.3696 14.5535 16.0197C13.1939 17.6698 11.524 18.904 9.54388 19.7225Z" fill="#FE0000"></path>
                </g>
              </svg>
            ) : courseType === 'pos' && index === 1 ? (
              <svg class="course-page__info-icon-svg" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <mask id="course-info-mask-2" mask-type="alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="38" height="39">
                  <rect y="0.000244141" width="38" height="38" fill="#D9D9D9"></rect>
                </mask>
                <g mask="url(#course-info-mask-2)">
                  <path d="M31.1138 32.2214L32.2221 31.1131L29.293 28.1839V23.7506H27.7096V28.8172L31.1138 32.2214ZM15.8346 9.50057H22.168V6.3339H15.8346V9.50057ZM22.9003 34.1016C21.3565 32.5579 20.5846 30.6908 20.5846 28.5006C20.5846 26.3103 21.3565 24.4433 22.9003 22.8995C24.444 21.3558 26.311 20.5839 28.5013 20.5839C30.6916 20.5839 32.5586 21.3558 34.1023 22.8995C35.6461 24.4433 36.418 26.3103 36.418 28.5006C36.418 30.6908 35.6461 32.5579 34.1023 34.1016C32.5586 35.6454 30.6916 36.4172 28.5013 36.4172C26.311 36.4172 24.444 35.6454 22.9003 34.1016ZM6.33464 33.2506C5.4638 33.2506 4.71832 32.9405 4.09818 32.3204C3.47804 31.7002 3.16797 30.9547 3.16797 30.0839V12.6672C3.16797 11.7964 3.47804 11.0509 4.09818 10.4308C4.71832 9.81064 5.4638 9.50057 6.33464 9.50057H12.668V6.3339C12.668 5.46307 12.978 4.71758 13.5982 4.09744C14.2183 3.47731 14.9638 3.16724 15.8346 3.16724H22.168C23.0388 3.16724 23.7843 3.47731 24.4044 4.09744C25.0246 4.71758 25.3346 5.46307 25.3346 6.3339V9.50057H31.668C32.5388 9.50057 33.2843 9.81064 33.9044 10.4308C34.5246 11.0509 34.8346 11.7964 34.8346 12.6672V19.436C33.911 18.7763 32.9082 18.2749 31.8263 17.9318C30.7444 17.5888 29.636 17.4172 28.5013 17.4172C25.4402 17.4172 22.8277 18.4992 20.6638 20.6631C18.4999 22.827 17.418 25.4395 17.418 28.5006C17.418 29.3186 17.5037 30.1301 17.6753 30.9349C17.8468 31.7398 18.1173 32.5117 18.4867 33.2506H6.33464Z" fill="#FE0000"></path>
                </g>
              </svg>
            ) : courseType === 'pos' && index === 2 ? (
              <svg class="course-page__info-icon-svg" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <mask id="course-info-mask-3" mask-type="alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="38" height="39">
                  <rect y="0.000244141" width="38" height="38" fill="#D9D9D9"></rect>
                </mask>
                <g mask="url(#course-info-mask-3)">
                  <path d="M7.91883 33.2498C6.573 33.2498 5.6164 32.6494 5.04904 31.4487C4.48168 30.248 4.62022 29.1331 5.46466 28.1039L14.2522 17.4164V7.91642H12.6688C12.2202 7.91642 11.8442 7.76469 11.5407 7.46121C11.2372 7.15774 11.0855 6.7817 11.0855 6.33309C11.0855 5.88448 11.2372 5.50844 11.5407 5.20496C11.8442 4.90149 12.2202 4.74976 12.6688 4.74976H25.3355C25.7841 4.74976 26.1601 4.90149 26.4636 5.20496C26.7671 5.50844 26.9188 5.88448 26.9188 6.33309C26.9188 6.7817 26.7671 7.15774 26.4636 7.46121C26.1601 7.76469 25.7841 7.91642 25.3355 7.91642H23.7522V17.4164L32.5397 28.1039C33.3841 29.1331 33.5226 30.248 32.9553 31.4487C32.3879 32.6494 31.4313 33.2498 30.0855 33.2498H7.91883ZM11.0855 28.4998H26.9188L21.5355 22.1664H16.4688L11.0855 28.4998ZM7.91883 30.0831H30.0855L20.5855 18.5248V7.91642H17.4188V18.5248L7.91883 30.0831Z" fill="#FE0000"></path>
                </g>
              </svg>
            ) : (
              <span class="course-page__info-icon" aria-hidden="true"></span>
            )}
            <h2>{card.title}</h2>
            <p>{card.description}</p>
          </article>
        ))}
      </div>
    </div>

    <aside class="course-page__form-column course-page__form-column--post" id="course-form">
      <div class="course-page__form-sticky course-page__form-sticky--post">
        <CourseLeadForm
          client:load
          courseType={courseType}
          courseTitle={title}
          courseLabel={rawLabel ?? title}
          courseValue={courseValue}
          courseId={courseId}
          leadSubmitted={leadSubmitted}
          paymentPlanGroups={presentation.paymentPlanGroups}
          paymentPlanOptions={presentation.paymentPlanOptions}
          workloadOptions={presentation.workloadOptions}
          pricing={presentation.pricing}
          showInternshipInfoLink={presentation.showInternshipInfoLink}
        />
      </div>
    </aside>
  </section>
</div>
